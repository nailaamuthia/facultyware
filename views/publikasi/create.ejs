<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      const apply = (dark) => {
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      };
      document.addEventListener("basecoat:theme", (event) => {
        const mode = event.detail?.mode;
        apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
      });
    })();
  </script>
  <script>
    (function () {
      try {
        const storedTheme = localStorage.getItem("themeVariant");
        if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
      } catch (e) {}
    })();
  </script>

  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Tambah Publikasi — Sistem Publikasi B14</title>
  <link rel="stylesheet" href="/assets/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --fti-navy: #4a5568;
      --fti-navy-deep: #3d4658;
      --fti-blue: #6d7898;
      --fti-grey: #9ba4b8;
    }
    body { font-family: 'Inter', sans-serif; }

    .fti-page-header {
      background: linear-gradient(135deg, var(--fti-navy-deep) 0%, var(--fti-blue) 60%, var(--fti-grey) 100%);
      border-radius: 18px;
      padding: 26px 28px;
      color: #fff;
      position: relative;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(61, 70, 88, 0.18);
      margin-bottom: 24px;
    }
    .fti-page-header::after {
      content: "FTI";
      position: absolute;
      right: 24px;
      top: 12px;
      font-size: 4.5rem;
      font-weight: 800;
      letter-spacing: -4px;
      color: rgba(255,255,255,0.08);
      pointer-events: none;
    }
    .fti-page-header h1 { color: #fff; margin: 0 0 6px; }
    .fti-page-header p { color: rgba(255,255,255,0.88); margin: 0; }

    .fti-btn-primary { background: #fff; color: var(--fti-navy-deep); border: none; font-weight: 600; }
    .fti-btn-primary:hover { background: rgba(255,255,255,0.88); }
    .fti-btn-outline { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.35); }
    .fti-btn-outline:hover { background: rgba(255,255,255,0.2); }

    .fti-card { border-radius: 16px !important; box-shadow: 0 6px 18px rgba(61, 70, 88, 0.06); }

    .fti-card form input:focus,
    .fti-card form select:focus,
    .fti-card form textarea:focus {
      border-color: var(--fti-blue) !important;
      box-shadow: 0 0 0 3px rgba(109,120,152,0.18) !important;
      outline: none;
    }

    .fti-submit-btn {
      background: #008B4B;
      color: #fff;
      border: none;
      font-weight: 600;
    }
    .fti-submit-btn:hover { background: #00713c; }
  </style>
</head>

<body>
  <script>
    (() => {
      document.addEventListener("DOMContentLoaded", () => {
        const sidebar = document.getElementById("sidebar");
        if (!sidebar) return;
        const updateCurrentLinks = () => {
          const currentPath = window.location.pathname.replace(/\/$/, "");
          sidebar.querySelectorAll("a, button").forEach((item) => {
            const href = item.getAttribute("href");
            if (!href) { item.removeAttribute("aria-current"); return; }
            const url = new URL(href, window.location.origin);
            if (url.pathname.replace(/\/$/, "") === currentPath) {
              item.setAttribute("aria-current", "page");
            } else {
              item.removeAttribute("aria-current");
            }
          });
        };
        updateCurrentLinks();
      });
    })();
  </script>

  <%- include('../partials/sidebar') %>

  <main id="content">
    <%- include('../partials/topbar', { pageTitle: 'Tambah Publikasi' }) %>

    <div class="p-4 md:p-6">
      <div class="max-w-screen-lg mx-auto">

        <header class="fti-page-header">
          <div style="position:relative;z-index:1;">
            <h1 style="font-size:1.7rem;font-weight:800;">Tambah Publikasi</h1>
            <p>Masukkan data publikasi baru agar dapat tercatat pada sistem.</p>
            <div class="flex items-center gap-2" style="margin-top:18px;">
              <a href="/publikasi" class="btn-outline fti-btn-outline">← Kembali</a>
            </div>
          </div>
        </header>

        <div class="card fti-card">
          <header>
            <h2>Form Data Publikasi</h2>
            <p>Isi data publikasi sesuai informasi yang tersedia.</p>
          </header>
          <section>
            <% if (typeof error !== 'undefined' && error) { %>
              <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.3);color:#b91c1c;padding:12px 16px;border-radius:10px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;"><span style="font-size:1.1rem;flex-shrink:0;">⚠️</span><span style="white-space:normal;word-break:break-word;line-height:1.5;"><%= error %></span></div>
            <% } %>

            <form action="/publikasi/store" method="POST" class="form grid gap-6">
              <div class="grid gap-2">
                <label for="title">Judul Publikasi</label>
                <input type="text" id="title" name="title" placeholder="Contoh: Sistem Informasi Akademik Berbasis Web" required/>
              </div>

              <div class="grid gap-2">
                <label for="publication_type">Jenis Publikasi</label>
                <select id="publication_type" name="publication_type" required>
                  <option value="">-- Pilih Jenis Publikasi --</option>
                  <option value="Jurnal">Jurnal</option>
                  <option value="Prosiding">Prosiding</option>
                  <option value="Buku">Buku</option>
                  <option value="Artikel Media Massa">Artikel Media Massa</option>
                </select>
              </div>

              <div class="grid gap-2">
                <label for="publication_date">Tanggal Publikasi</label>
                <input type="date" id="publication_date" name="publication_date" required/>
              </div>

              <div class="grid gap-2">
                <label for="doi">DOI</label>
                <input type="text" id="doi" name="doi" placeholder="Contoh: 10.1234/nama.tahun.001" pattern="^10\.\d{4,}\/\S+$" title="Format DOI harus diawali 10. contoh: 10.1234/abc.001"/>
              </div>

              <div class="grid gap-2">
                <label for="url">URL Publikasi</label>
                <input type="url" id="url" name="url" placeholder="Contoh: https://journal.unand.ac.id/artikel"/>
              </div>

              <div class="grid gap-2">
                <label for="abstract">Abstract</label>
                <textarea id="abstract" name="abstract" placeholder="Contoh: Penelitian ini membahas pengembangan sistem informasi berbasis web menggunakan ExpressJS dan MySQL..." rows="5"></textarea>
              </div>

              <footer class="flex items-center gap-3">
                <button type="submit" class="btn fti-submit-btn">Simpan Publikasi</button>
                <a href="/publikasi" class="btn-outline">Batal</a>
              </footer>
            </form>
          </section>
        </div>

      </div>
    </div>
  </main>

  <div id="toaster" class="toaster"></div>
  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
  <script src="/assets/js/popover.js" defer></script>
  <script src="/assets/js/toast.js" defer></script>
</body>
</html>
