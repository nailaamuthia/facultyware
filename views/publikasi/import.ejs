<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      const apply = (dark) => {
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      };
      document.addEventListener("basecoat:theme", (event) => {
        const mode = event.detail?.mode;
        apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
      });
    })();
  </script>
  <script>
    (function () {
      try {
        const storedTheme = localStorage.getItem("themeVariant");
        if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
      } catch (e) {}
    })();
  </script>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Import Publikasi — Sistem Publikasi B14</title>
  <link rel="stylesheet" href="/assets/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --fti-navy: #4a5568;
      --fti-navy-deep: #3d4658;
      --fti-blue: #6d7898;
      --fti-grey: #9ba4b8;
    }
    body { font-family: 'Inter', sans-serif; }

    .fti-page-header {
      background: linear-gradient(135deg, var(--fti-navy-deep) 0%, var(--fti-blue) 60%, var(--fti-grey) 100%);
      border-radius: 18px;
      padding: 26px 28px;
      color: #fff;
      position: relative;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(61, 70, 88, 0.18);
      margin-bottom: 24px;
    }
    .fti-page-header::after {
      content: "FTI";
      position: absolute;
      right: 24px;
      top: 12px;
      font-size: 4.5rem;
      font-weight: 800;
      letter-spacing: -4px;
      color: rgba(255,255,255,0.08);
      pointer-events: none;
    }
    .fti-page-header h1 { color: #fff; margin: 0 0 6px; }
    .fti-page-header p { color: rgba(255,255,255,0.88); margin: 0; }

    .fti-btn-outline { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.35); }
    .fti-btn-outline:hover { background: rgba(255,255,255,0.2); }

    .fti-card { border-radius: 16px !important; box-shadow: 0 6px 18px rgba(61, 70, 88, 0.06); }

    .fti-template-btn {
      background: rgba(109,120,152,0.1);
      color: var(--fti-navy-deep);
      border: 1px solid rgba(109,120,152,0.3);
    }
    .fti-template-btn:hover { background: rgba(109,120,152,0.18); }

    .fti-submit-btn { background: #008B4B; color: #fff; border: none; font-weight: 600; }
    .fti-submit-btn:hover { background: #00713c; }

    .fti-alert-success {
      background: rgba(34,197,94,0.1);
      border: 1px solid rgba(34,197,94,0.35);
      color: #15803d;
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .fti-alert-error {
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.3);
      color: #b91c1c;
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .fti-format-table thead tr { background: rgba(109,120,152,0.1) !important; }
    .fti-format-table th { color: var(--fti-navy-deep) !important; }
  </style>
</head>
<body>
  <%- include('../partials/sidebar') %>

  <main id="content">
    <%- include('../partials/topbar', { pageTitle: 'Import Publikasi' }) %>

    <div class="p-4 md:p-6">
      <div class="max-w-screen-lg mx-auto">

        <header class="fti-page-header">
          <div style="position:relative;z-index:1;">
            <h1 style="font-size:1.7rem;font-weight:800;">Import Publikasi</h1>
            <p>Upload file Excel untuk import data publikasi secara massal.</p>
            <div class="flex items-center gap-2" style="margin-top:18px;">
              <a href="/publikasi" class="btn-outline fti-btn-outline">← Kembali</a>
            </div>
          </div>
        </header>

        <% if (success) { %>
          <div class="fti-alert-success">
            ✅ <%= success %>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="fti-alert-error">
            ❌ <%= error %>
          </div>
        <% } %>

        <div class="card fti-card">
          <header>
            <h2>Upload File Excel</h2>
            <p>Pilih file Excel (.xlsx) yang berisi data publikasi.</p>
          </header>
          <section>
            <div style="margin-bottom:16px;">
              <a href="/publikasi/import/template" class="btn-outline fti-template-btn">
                ⬇ Download Template Excel
              </a>
              <p class="text-sm text-muted-foreground" style="margin-top:8px;">Download template Excel, isi datanya, lalu upload di bawah.</p>
            </div>

            <form action="/publikasi/import" method="POST" enctype="multipart/form-data" class="form grid gap-6">
              <div class="grid gap-2">
                <label for="file">File Excel (.xlsx)</label>
                <input type="file" id="file" name="file" accept=".xlsx" required/>
              </div>
              <footer class="flex items-center gap-3">
                <button type="submit" class="btn fti-submit-btn">Import Data</button>
                <a href="/publikasi" class="btn-outline">Batal</a>
              </footer>
            </form>
          </section>
        </div>

        <div class="card" style="margin-top:16px;">
          <header>
            <h2>Format File Excel</h2>
            <p>Pastikan file Excel kamu mengikuti format berikut.</p>
          </header>
          <section>
            <table style="width:100%;border-collapse:collapse;font-size:0.88rem;" class="fti-format-table">
              <thead>
                <tr style="background:var(--color-secondary);">
                  <th style="padding:10px 12px;text-align:left;border:1px solid var(--color-border);">Kolom A</th>
                  <th style="padding:10px 12px;text-align:left;border:1px solid var(--color-border);">Kolom B</th>
                  <th style="padding:10px 12px;text-align:left;border:1px solid var(--color-border);">Kolom C</th>
                  <th style="padding:10px 12px;text-align:left;border:1px solid var(--color-border);">Kolom D</th>
                  <th style="padding:10px 12px;text-align:left;border:1px solid var(--color-border);">Kolom E</th>
                  <th style="padding:10px 12px;text-align:left;border:1px solid var(--color-border);">Kolom F</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);font-weight:600;">Judul Publikasi*</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);">Jenis Publikasi</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);">Tanggal (YYYY-MM-DD)</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);">DOI</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);">URL</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);">Abstrak</td>
                </tr>
                <tr style="background:var(--color-secondary);">
                  <td style="padding:10px 12px;border:1px solid var(--color-border);color:var(--color-muted-foreground);">Sistem Informasi Web</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);color:var(--color-muted-foreground);">Jurnal</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);color:var(--color-muted-foreground);">2026-06-01</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);color:var(--color-muted-foreground);">10.1234/abc.001</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);color:var(--color-muted-foreground);">https://...</td>
                  <td style="padding:10px 12px;border:1px solid var(--color-border);color:var(--color-muted-foreground);">Abstrak penelitian...</td>
                </tr>
              </tbody>
            </table>
            <p class="text-sm text-muted-foreground" style="margin-top:12px;">* Baris pertama adalah header, baris data mulai dari baris ke-2. Kolom bertanda * wajib diisi.</p>
          </section>
        </div>

      </div>
    </div>
  </main>

  <div id="toaster" class="toaster"></div>
  <script src="/assets/js/basecoat.js" defer></script>
  <script src="/assets/js/sidebar.js" defer></script>
  <script src="/assets/js/popover.js" defer></script>
  <script src="/assets/js/toast.js" defer></script>
</body>
</html>
