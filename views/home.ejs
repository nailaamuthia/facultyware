    <style>
      :root {
        --fti-navy: #4a5568;
        --fti-navy-deep: #3d4658;
        --fti-blue: #6d7898;
        --fti-grey: #9ba4b8;
      }

      body { font-family: 'Inter', sans-serif; }

      .fti-hero {
        background:
          radial-gradient(circle at top right, rgba(255,255,255,0.18), transparent 35%),
          linear-gradient(135deg, var(--fti-navy-deep) 0%, var(--fti-blue) 55%, var(--fti-grey) 100%);
        border-radius: 20px;
        padding: 30px 32px;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 14px 32px rgba(61, 70, 88, 0.22);
      }

      .fti-hero::after {
        content: "FTI";
        position: absolute;
        right: 28px;
        top: 18px;
        font-size: 6.5rem;
        font-weight: 800;
        letter-spacing: -6px;
        color: rgba(255,255,255,0.08);
        pointer-events: none;
      }

      .fti-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.14);
        border: 1px solid rgba(0,139,75,0.45);
        backdrop-filter: blur(6px);
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        margin-bottom: 14px;
      }

      .fti-stat-card {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 18px 20px;
        box-shadow: 0 6px 18px rgba(61, 70, 88, 0.06);
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .fti-stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .fti-stat-value {
        font-size: 1.85rem;
        font-weight: 800;
        line-height: 1;
        color: var(--color-foreground);
      }

      .fti-stat-label {
        font-size: 0.82rem;
        color: var(--color-muted-foreground);
        font-weight: 500;
        margin-top: 4px;
      }

      .fti-card {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(61, 70, 88, 0.06);
        overflow: hidden;
      }

      .fti-card-header {
        padding: 18px 20px;
        border-bottom: 1px solid var(--color-border);
      }

      .fti-card-header h2 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: var(--color-foreground);
      }

      .fti-card-header p {
        margin: 3px 0 0;
        font-size: 0.82rem;
        color: var(--color-muted-foreground);
      }

      .fti-type-badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
      }

      .fti-type-jurnal {
        background: rgba(109, 120, 152, 0.14);
        color: var(--fti-navy-deep);
      }

      .fti-type-prosiding {
        background: rgba(155, 164, 184, 0.18);
        color: var(--fti-navy);
      }

      .fti-btn-primary {
        background: #008B4B;
        color: #fff;
        border: none;
      }

      .fti-btn-primary:hover {
        background: #00713c;
      }
    </style>

