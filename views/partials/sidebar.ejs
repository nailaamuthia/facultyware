<style>
  #sidebar {
    background-color: #fcfdfc !important;
    border-right: 1px solid #e0e8e3 !important;
    box-shadow: 4px 0 15px rgba(0, 107, 53, 0.03) !important;
  }

  #sidebar nav > header a,
  #sidebar nav > header a span,
  #sidebar section h3,
  #sidebar section a,
  #sidebar section a span,
  #sidebar footer button,
  #sidebar footer button span,
  #sidebar footer .text-muted-foreground {
    color: #1a2e22 !important;
  }

  #sidebar section a svg {
    color: #4a6353 !important;
    stroke: #4a6353 !important;
  }

  #sidebar section a:hover {
    background-color: #e8f0eb !important;
  }

  #sidebar section a[aria-current="page"] {
    background-color: #e8f0eb !important;
    border-left: 3px solid #006B35 !important;
    font-weight: 600 !important;
  }

  #sidebar section a[aria-current="page"] span,
  #sidebar section a[aria-current="page"] svg {
    color: #006B35 !important;
    stroke: #006B35 !important;
  }

  .dark #sidebar {
    background-color: #0f172a !important;
    border-right: 1px solid #1e293b !important;
    box-shadow: 4px 0 15px rgba(0, 0, 0, 0.25) !important;
  }

  .dark #sidebar * {
    color: #e5e7eb !important;
    stroke: #e5e7eb !important;
  }

  .dark #sidebar section a svg,
  .dark #sidebar nav > header a svg {
    color: #cbd5e1 !important;
    stroke: #cbd5e1 !important;
    fill: none !important;
  }

  .dark #sidebar section a:hover {
    background-color: #1e293b !important;
  }

  .dark #sidebar section a[aria-current="page"] {
    background-color: #1e293b !important;
    border-left: 3px solid #38bdf8 !important;
  }

  .dark #sidebar section a[aria-current="page"] span,
  .dark #sidebar section a[aria-current="page"] svg {
    color: #38bdf8 !important;
    stroke: #38bdf8 !important;
  }

  /* Popover user di footer */
  .dark #sidebar-user-popover-popover,
  .dark [data-popover]#sidebar-user-popover-popover {
    background-color: #1e293b !important;
    border-color: #334155 !important;
    color: #e5e7eb !important;
  }

  .dark #sidebar-user-popover-popover *:not(a) {
    color: #e5e7eb !important;
    border-color: #475569 !important;
  }

  .dark #sidebar-user-popover-popover a[href="/logout"] {
    color: #f87171 !important;
    border-color: #f87171 !important;
  }
</style>

<aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
  <nav aria-label="Sidebar navigation">
    <header>
      <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
        <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg" style="background-color:#006B35;color:white;">
          <!-- Heroicon: Academic Cap -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.84 4.945v3.477l-7 3.5-7-3.5v-3.477a12.083 12.083 0 01.84-4.945L12 14z"/>
          </svg>
        </div>
        <div class="grid flex-1 text-left text-sm leading-tight">
          <span class="truncate font-semibold">Sistem Publikasi</span>
          <span class="truncate text-xs text-muted-foreground">Kelompok B14 · PWEB</span>
        </div>
      </a>
    </header>

    <section class="scrollbar">
      <!-- Navigasi -->
      <div role="group">
        <h3 class="px-2 font-semibold" style="opacity:0.6;">Navigasi</h3>
        <ul>
          <li>
            <a href="/home">
              <!-- Icon Home -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9v9a3 3 0 0 1-3 3h-3v-6h-6v6H6a3 3 0 0 1-3-3v-9z"/>
              </svg>
              <span>Home</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Publikasi -->
      <div role="group">
        <h3 class="px-2 font-semibold" style="opacity:0.6;margin-top:1rem;">Publikasi</h3>
        <ul>
          <li>
            <a href="/publikasi">
              <!-- Icon Document -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l5 5v11a2 2 0 01-2 2z"/>
              </svg>
              <span>Daftar Publikasi</span>
            </a>
          </li>

          <li>
            <a href="/publikasi/create">
              <!-- Icon Plus -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
              <span>Tambah Publikasi</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Pengelolaan -->
      <div role="group">
        <h3 class="px-2 font-semibold" style="opacity:0.6;margin-top:1rem;">Pengelolaan</h3>
        <ul>
          <li>
            <a href="#">
              <!-- Icon User -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A8.966 8.966 0 0112 15c2.386 0 4.566.938 6.121 2.804M12 7a4 4 0 100-8 4 4 0 000 8z"/>
              </svg>
              <span>Penulis Publikasi</span>
            </a>
          </li>

          <li>
            <a href="#">
              <!-- Icon Badge Check -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M12 22c5-2 5-10 0-12s-5 10 0 12z"/>
              </svg>
              <span>Approval Publikasi</span>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- Footer User -->
    <footer>
      <div id="sidebar-user-popover" class="popover">
        <button
          id="sidebar-user-popover-trigger"
          type="button"
          aria-expanded="false"
          aria-controls="sidebar-user-popover-popover"
          class="btn-ghost p-2 h-12 w-full flex items-center justify-start"
          data-keep-mobile-sidebar-open="">
          <div class="bg-primary text-primary-foreground flex aspect-square size-8 items-center justify-center rounded-full font-semibold text-sm" style="background-color:#006B35;color:white;">
            <%= locals.user ? locals.user.name.charAt(0).toUpperCase() : 'U' %>
          </div>
          <div class="grid flex-1 text-left text-sm leading-tight">
            <span class="truncate font-medium"><%= locals.user ? locals.user.name : 'User' %></span>
            <span class="truncate text-xs capitalize text-muted-foreground"><%= locals.user ? locals.user.role : '' %></span>
          </div>
        </button>

        <div id="sidebar-user-popover-popover" data-popover aria-hidden="true" data-side="top" class="w-[240px]">
          <div class="grid gap-3">
            <header class="grid gap-0.5">
              <h2 class="font-semibold text-sm"><%= locals.user ? locals.user.name : 'User' %></h2>
              <p class="text-xs text-muted-foreground"><%= locals.user ? locals.user.email : '' %></p>
              <span class="badge badge-outline capitalize text-xs w-fit">
                <%= locals.user ? locals.user.role : '' %>
              </span>
            </header>

            <footer>
              <a href="/logout" class="btn-sm-outline w-full" style="color:#ef4444;border-color:#ef4444;">
                Logout
              </a>
            </footer>
          </div>
        </div>
      </div>
    </footer>
  </nav>
</aside>