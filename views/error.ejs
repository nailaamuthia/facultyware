<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Error</title>
  <link rel="stylesheet" href="/assets/styles.css"/>
</head>
<body>
  <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:16px;padding:24px;">
    <h1 style="font-size:4rem;font-weight:800;margin:0;"><%= typeof error !== 'undefined' && error.status ? error.status : '500' %></h1>
    <h2 style="font-size:1.2rem;font-weight:600;margin:0;"><%= typeof message !== 'undefined' ? message : 'Terjadi kesalahan.' %></h2>
    <a href="/home" style="margin-top:8px;padding:10px 20px;background:#006B35;color:white;border-radius:8px;text-decoration:none;font-weight:600;">Kembali ke Home</a>
  </div>
</body>
</html>