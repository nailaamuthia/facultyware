<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      const apply = (dark) => {
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      };
      document.addEventListener("basecoat:theme", (event) => {
        const mode = event.detail?.mode;
        apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
      });
    })();
  </script>
  <script>
    (function () {
      try {
        const storedTheme = localStorage.getItem("themeVariant");
        if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
      } catch (e) {}
    })();
  </script>

  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Edit Penulis Publikasi — Sistem Publikasi B14</title>
  <link rel="stylesheet" href="/assets/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --fti-navy: #4a5568;
      --fti-navy-deep: #3d4658;
      --fti-blue: #6d7898;
      --fti-grey: #9ba4b8;
    }

    body { font-family: 'Inter', sans-serif; }

    .fti-page-header {
      background: linear-gradient(135deg, var(--fti-navy-deep) 0%, var(--fti-blue) 60%, var(--fti-grey) 100%);
      border-radius: 18px;
      padding: 26px 28px;
      color: #fff;
      position: relative;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(61, 70, 88, 0.18);
      margin-bottom: 24px;
    }

    .fti-page-header::after {
      content: "FTI";
      position: absolute;
      right: 24px;
      top: 12px;
      font-size: 4.5rem;
      font-weight: 800;
      letter-spacing: -4px;
      color: rgba(255,255,255,0.08);
      pointer-events: none;
    }

    .fti-page-header h1 { color: #fff; margin: 0 0 6px; }
    .fti-page-header p { color: rgba(255,255,255,0.88); margin: 0; }

    .fti-btn-back {
      background: rgba(255,255,255,0.12);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.35);
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .fti-btn-back:hover { background: rgba(255,255,255,0.2); }

    .form-group {
      margin-bottom: 20px;
      display: flex;
      flex-direction: column;
    }

    .form-group label {
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--color-foreground);
      font-size: 0.95rem;
    }

    .form-group input,
    .form-group textarea {
      padding: 10px 12px;
      border: 1px solid var(--color-border);
      border-radius: 8px;
      background: var(--color-background);
      color: var(--color-foreground);
      font-size: 0.95rem;
      font-family: inherit;
    }

    .form-group textarea {
      resize: vertical;
      min-height: 100px;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #008B4B;
      box-shadow: 0 0 0 3px rgba(0, 139, 75, 0.1);
    }

    .form-group small {
      color: var(--color-muted-foreground);
      font-size: 0.85rem;
      margin-top: 4px;
    }

    .error-message {
      padding: 12px 16px;
      background: #fee;
      border: 1px solid #fcc;
      border-radius: 8px;
      color: #c33;
      margin-bottom: 20px;
      font-weight: 500;
    }

    .form-actions {
      display: flex;
      gap: 12px;
      margin-top: 28px;
    }

    .btn-submit {
      background: #008B4B;
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.95rem;
    }

    .btn-submit:hover {
      background: #007039;
    }

    .btn-cancel {
      background: var(--color-secondary);
      color: var(--color-secondary-foreground);
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.95rem;
      text-decoration: none;
      display: inline-block;
    }

    .btn-cancel:hover {
      opacity: 0.8;
    }

    .fti-card {
      border-radius: 16px !important;
      box-shadow: 0 6px 18px rgba(61, 70, 88, 0.06);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <script>
    (() => {
      document.addEventListener("DOMContentLoaded", () => {
        const sidebar = document.getElementById("sidebar");
        if (!sidebar) return;
        const updateCurrentLinks = () => {
          const currentPath = window.location.pathname.replace(/\/$/, "");
          sidebar.querySelectorAll("a, button").forEach((item) => {
            const href = item.getAttribute("href");
            if (!href) { item.removeAttribute("aria-current"); return; }
            const url = new URL(href, window.location.origin);
            const itemPath = url.pathname.replace(/\/$/, "");
            if (itemPath === currentPath) {
              item.setAttribute("aria-current", "page");
            } else {
              item.removeAttribute("aria-current");
            }
          });
        };
        updateCurrentLinks();
      });
    })();
  </script>

  <%- include('../partials/sidebar') %>

  <main id="content">
    <%- include('../partials/topbar', { pageTitle: 'Edit Penulis Publikasi' }) %>

    <div class="p-4 md:p-6">
      <div class="max-w-screen-lg mx-auto">

        <!-- Header -->
        <header class="fti-page-header">
          <div style="position:relative;z-index:1;">
            <h1 style="font-size:1.7rem;font-weight:800;">Edit Penulis Publikasi</h1>
            <p>Perbarui informasi penulis publikasi yang telah ada.</p>
            <div class="flex w-full items-center justify-start gap-2" style="margin-top:18px;">
              <a class="btn fti-btn-back" href="/authors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Kembali
              </a>
            </div>
          </div>
        </header>

        <!-- Form Card -->
        <div class="card fti-card">
          <header>
            <h2>Form Edit Penulis</h2>
            <p>Ubah informasi penulis publikasi di bawah ini.</p>
          </header>

          <section style="padding:24px;">
            <% if (error) { %>
              <div class="error-message"><%= error %></div>
            <% } %>

            <form action="/authors/<%= author.id %>/update" method="POST">
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Nama Penulis *</label>
                  <input type="text" id="name" name="name" value="<%= author.name || '' %>" placeholder="Contoh: Dr. Ahmad Saputra" required/>
                  <small>Nama lengkap penulis publikasi</small>
                </div>

                <div class="form-group">
                  <label for="email">Email</label>
                  <input type="email" id="email" name="email" value="<%= author.email || '' %>" placeholder="nama@institusi.ac.id"/>
                  <small>Alamat email penulis (opsional)</small>
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="institution">Institusi</label>
                  <input type="text" id="institution" name="institution" value="<%= author.institution || '' %>" placeholder="Contoh: Universitas Andalas"/>
                  <small>Institusi tempat penulis bekerja (opsional)</small>
                </div>

                <div class="form-group">
                  <label for="expertise">Keahlian</label>
                  <input type="text" id="expertise" name="expertise" value="<%= author.expertise || '' %>" placeholder="Contoh: Machine Learning, IoT"/>
                  <small>Bidang keahlian penulis (opsional)</small>
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn-submit">Perbarui Penulis</button>
                <a href="/authors/<%= author.id %>" class="btn-cancel">Batal</a>
              </div>
            </form>
          </section>
        </div>

      </div>
    </div>
  </main>
</body>
</html>
