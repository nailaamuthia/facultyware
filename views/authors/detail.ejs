<!doctype html>
<html lang="id">
<head>
  <script>
    (() => {
      try {
        const stored = localStorage.getItem("themeMode");
        if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.add("dark");
        }
      } catch (_) {}
      const apply = (dark) => {
        document.documentElement.classList.toggle("dark", dark);
        try { localStorage.setItem("themeMode", dark ? "dark" : "light"); } catch (_) {}
      };
      document.addEventListener("basecoat:theme", (event) => {
        const mode = event.detail?.mode;
        apply(mode === "dark" ? true : mode === "light" ? false : !document.documentElement.classList.contains("dark"));
      });
    })();
  </script>
  <script>
    (function () {
      try {
        const storedTheme = localStorage.getItem("themeVariant");
        if (storedTheme) document.documentElement.classList.add(`theme-${storedTheme}`);
      } catch (e) {}
    })();
  </script>

  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Detail Penulis Publikasi — Sistem Publikasi B14</title>
  <link rel="stylesheet" href="/assets/styles.css"/>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --fti-navy: #4a5568;
      --fti-navy-deep: #3d4658;
      --fti-blue: #6d7898;
      --fti-grey: #9ba4b8;
    }

    body { font-family: 'Inter', sans-serif; }

    .fti-page-header {
      background: linear-gradient(135deg, var(--fti-navy-deep) 0%, var(--fti-blue) 60%, var(--fti-grey) 100%);
      border-radius: 18px;
      padding: 26px 28px;
      color: #fff;
      position: relative;
      overflow: hidden;
      box-shadow: 0 12px 28px rgba(61, 70, 88, 0.18);
      margin-bottom: 24px;
    }

    .fti-page-header::after {
      content: "FTI";
      position: absolute;
      right: 24px;
      top: 12px;
      font-size: 4.5rem;
      font-weight: 800;
      letter-spacing: -4px;
      color: rgba(255,255,255,0.08);
      pointer-events: none;
    }

    .fti-page-header h1 { color: #fff; margin: 0 0 6px; }
    .fti-page-header p { color: rgba(255,255,255,0.88); margin: 0; }

    .fti-btn-back {
      background: rgba(255,255,255,0.12);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.35);
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .fti-btn-back:hover { background: rgba(255,255,255,0.2); }

    .fti-btn-primary {
      background: #fff;
      color: #00713c;
      border: 1.5px solid #008B4B;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .fti-btn-primary:hover { background: rgba(255,255,255,0.88); }

    .fti-card {
      border-radius: 16px !important;
      box-shadow: 0 6px 18px rgba(61, 70, 88, 0.06);
    }

    .detail-section {
      padding: 24px;
    }

    .detail-field {
      margin-bottom: 20px;
    }

    .detail-label {
      font-weight: 600;
      color: var(--color-muted-foreground);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }

    .detail-value {
      color: var(--color-foreground);
      font-size: 1rem;
    }

    .badge-institution {
      display: inline-flex;
      align-items: center;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 600;
      background: rgba(0, 139, 75, 0.12);
      color: #008B4B;
    }

    .publication-list {
      margin-top: 30px;
    }

    .publication-item {
      padding: 16px;
      border: 1px solid var(--color-border);
      border-radius: 8px;
      margin-bottom: 12px;
      background: var(--color-secondary);
    }

    .publication-item h4 {
      margin: 0 0 8px 0;
      color: var(--color-foreground);
      font-weight: 600;
    }

    .publication-item p {
      margin: 4px 0;
      color: var(--color-muted-foreground);
      font-size: 0.9rem;
    }

    .publication-item a {
      color: #008B4B;
      text-decoration: none;
      font-weight: 600;
    }

    .publication-item a:hover {
      text-decoration: underline;
    }

    .empty-message {
      text-align: center;
      padding: 32px 16px;
      color: var(--color-muted-foreground);
    }

    .empty-message svg {
      margin-bottom: 12px;
      opacity: 0.5;
    }

    .action-buttons {
      display: flex;
      gap: 12px;
      margin-top: 24px;
    }

    .btn-edit {
      background: #008B4B;
      color: white;
      border: none;
      padding: 10px 16px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }

    .btn-edit:hover {
      background: #007039;
    }

    .btn-delete {
      background: #ef4444;
      color: white;
      border: none;
      padding: 10px 16px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .btn-delete:hover {
      background: #dc2626;
    }

    table tbody tr {
      border-bottom: 1px solid var(--color-border);
    }

    table tbody tr:hover {
      background: rgba(109,120,152,0.05);
    }
  </style>
</head>

<body>
  <script>
    (() => {
      document.addEventListener("DOMContentLoaded", () => {
        const sidebar = document.getElementById("sidebar");
        if (!sidebar) return;
        const updateCurrentLinks = () => {
          const currentPath = window.location.pathname.replace(/\/$/, "");
          sidebar.querySelectorAll("a, button").forEach((item) => {
            const href = item.getAttribute("href");
            if (!href) { item.removeAttribute("aria-current"); return; }
            const url = new URL(href, window.location.origin);
            const itemPath = url.pathname.replace(/\/$/, "");
            if (itemPath === currentPath) {
              item.setAttribute("aria-current", "page");
            } else {
              item.removeAttribute("aria-current");
            }
          });
        };
        updateCurrentLinks();
      });
    })();
  </script>

  <%- include('../partials/sidebar') %>

  <main id="content">
    <%- include('../partials/topbar', { pageTitle: 'Detail Penulis Publikasi' }) %>

    <div class="p-4 md:p-6">
      <div class="max-w-screen-lg mx-auto">

        <!-- Header -->
        <header class="fti-page-header">
          <div style="position:relative;z-index:1;">
            <h1 style="font-size:1.7rem;font-weight:800;"><%= author.name || '-' %></h1>
            <p><%= author.institution || 'Institusi tidak tersedia' %></p>
            <div class="flex w-full items-center justify-start gap-2" style="margin-top:18px;">
              <a class="btn fti-btn-back" href="/authors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Kembali
              </a>
            </div>
          </div>
        </header>

        <!-- Detail Card -->
        <div class="card fti-card">
          <header>
            <h2>Informasi Penulis</h2>
            <p>Informasi lengkap profil penulis publikasi</p>
          </header>

          <div class="detail-section">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px;">
              <div>
                <div class="detail-field">
                  <div class="detail-label">Nama Penulis</div>
                  <div class="detail-value"><%= author.name || '-' %></div>
                </div>

                <div class="detail-field">
                  <div class="detail-label">Email</div>
                  <div class="detail-value">
                    <% if (author.email) { %>
                      <a href="mailto:<%= author.email %>" style="color: #008B4B; text-decoration: none;">
                        <%= author.email %>
                      </a>
                    <% } else { %>
                      <span style="color: var(--color-muted-foreground);">-</span>
                    <% } %>
                  </div>
                </div>
              </div>

              <div>
                <div class="detail-field">
                  <div class="detail-label">Institusi</div>
                  <div class="detail-value">
                    <% if (author.institution) { %>
                      <span class="badge-institution"><%= author.institution %></span>
                    <% } else { %>
                      <span style="color: var(--color-muted-foreground);">-</span>
                    <% } %>
                  </div>
                </div>

                <div class="detail-field">
                  <div class="detail-label">Keahlian</div>
                  <div class="detail-value">
                    <% if (author.expertise) { %>
                      <%= author.expertise %>
                    <% } else { %>
                      <span style="color: var(--color-muted-foreground);">-</span>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>

            <div class="action-buttons">
              <a href="/authors/<%= author.id %>/edit" class="btn-edit">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                Edit
              </a>
              <form action="/authors/<%= author.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Yakin ingin menghapus penulis ini?');">
                <button type="submit" class="btn-delete">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                  Hapus
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Publications Card -->
        <div class="card fti-card" style="margin-top: 24px;">
          <header>
            <h2>Publikasi Terkait</h2>
            <p>Daftar publikasi yang melibatkan penulis ini</p>
          </header>

          <section style="padding: 24px;">
            <% if (publications && publications.length > 0) { %>
              <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                <thead>
                  <tr style="border-bottom: 1px solid var(--color-border);">
                    <th style="text-align: left; padding: 12px; color: var(--color-muted-foreground); font-weight: 600;">Judul</th>
                    <th style="text-align: left; padding: 12px; color: var(--color-muted-foreground); font-weight: 600;">Jenis</th>
                    <th style="text-align: left; padding: 12px; color: var(--color-muted-foreground); font-weight: 600;">Tanggal</th>
                    <th style="text-align: center; padding: 12px; color: var(--color-muted-foreground); font-weight: 600;">Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% publications.forEach((pub) => { %>
                    <tr>
                      <td style="padding: 12px; color: var(--color-foreground); font-weight: 500;">
                        <%= pub.title || '-' %>
                      </td>
                      <td style="padding: 12px;">
                        <% const jenisKey = (pub.publication_type || '').toLowerCase(); %>
                        <% if (jenisKey === 'jurnal') { %>
                          <span style="display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: rgba(109,120,152,0.14); color: #3d4658;">Jurnal</span>
                        <% } else if (jenisKey === 'prosiding') { %>
                          <span style="display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: rgba(155,164,184,0.2); color: #4a5568;">Prosiding</span>
                        <% } else if (jenisKey === 'buku') { %>
                          <span style="display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: rgba(180,140,90,0.16); color: #92622f;">Buku</span>
                        <% } else if (pub.publication_type) { %>
                          <span style="display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; background: var(--color-secondary); color: var(--color-secondary-foreground);"><%= pub.publication_type %></span>
                        <% } %>
                      </td>
                      <td style="padding: 12px; color: var(--color-muted-foreground);">
                        <%= pub.publication_date ? new Date(pub.publication_date).toLocaleDateString('id-ID') : '-' %>
                      </td>
                      <td style="padding: 12px; text-align: center;">
                        <a href="/publikasi/<%= pub.id %>" title="Lihat Detail" style="color: #008B4B; text-decoration: none; font-weight: 600;">
                          Lihat
                        </a>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            <% } else { %>
              <div class="empty-message">
                <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <p>Belum ada publikasi yang terkait dengan penulis ini.</p>
              </div>
            <% } %>
          </section>
        </div>

      </div>
    </div>
  </main>
</body>
</html>
